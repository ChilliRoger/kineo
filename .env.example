# .env.example
# Template for environment variables - copy to .env and fill in your values

# Gemini API Key - Get from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=

# Google Cloud Project Configuration
GCP_PROJECT_ID=
GCP_REGION=us-central1

# Firestore Collections
FIRESTORE_COLLECTION_CUSTOMERS=kineo_customers
FIRESTORE_COLLECTION_SESSIONS=kineo_sessions
